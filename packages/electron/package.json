{
  "name": "@volute/electron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron dist/main.js",
    "build": "npm run download-node && tsc && electron-builder",
    "pack": "npm run download-node && tsc && electron-builder --dir",
    "download-node": "tsx scripts/download-node.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
