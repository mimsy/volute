{
  "name": "@volute/web",
  "version": "0.0.1",
  "description": "Standalone Volute web UI — connect to any Volute daemon",
  "type": "module",
  "bin": {
    "volute-web": "./dist/serve.js"
  },
  "scripts": {
    "build": "npm run build:ui && npm run build:server",
    "build:ui": "vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "dev": "vite dev"
  },
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@volute/api": "*",
    "@volute/ui": "*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.5.0",
    "dompurify": "^3.3.3",
    "marked": "^17.0.5",
    "svelte": "^5.55.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
