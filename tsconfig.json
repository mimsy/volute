{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "lib": ["ES2022"]
  },
  "include": ["src", "packages/cli/src", "packages/daemon/src"],
  "exclude": ["packages/web/src/ui"]
}
